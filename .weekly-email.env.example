# Copy to `.weekly-email.env` on the administrator's Mac and keep that real file uncommitted.
# You can also omit secret values here and store them in macOS Keychain under service
# `farmhannong-weekly-email` with account names matching the variable names below.

SUMMARY_EMAIL_RECIPIENTS=person1@example.com,person2@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-account@example.com
SMTP_PASSWORD=app-password-or-keychain
SMTP_FROM=your-account@example.com
SITE_URL=https://ziopeno.github.io/farmhannong-agro-weekly-db/
